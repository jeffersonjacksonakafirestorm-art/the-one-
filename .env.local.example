# ─────────────────────────────────────────────
# Actionable AI — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Supabase (supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxxxxxx

# Resend (resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Stripe (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_BASIC_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Session secret (random 32+ char string)
SESSION_SECRET=change-this-to-a-random-secret-string-32chars

# Actionable AI — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# App URL
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Anthropic (Claude AI)
# Get from: console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (Email)
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@yourdomain.com

# Stripe
# Get from: stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create at stripe.com → Products
# Basic plan: $15/month recurring
STRIPE_BASIC_PRICE_ID=price_...
# Pro plan: $49/month recurring
STRIPE_PRO_PRICE_ID=price_...

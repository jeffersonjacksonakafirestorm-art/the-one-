# -------------------------------------------------------
# Gumroad product URLs
# Copy these into Vercel → Project Settings → Environment Variables
# -------------------------------------------------------

# Your Gumroad product URL for the day trading course
# e.g. https://yourname.gumroad.com/l/trading-foundations
NEXT_PUBLIC_GUMROAD_TRADING_URL=

# Your Gumroad product URL for the fitness program
# e.g. https://yourname.gumroad.com/l/fitness-program
NEXT_PUBLIC_GUMROAD_FITNESS_URL=

# -------------------------------------------------------
# Email provider (optional — for the lead magnet form)
# Uncomment and fill in once you pick a provider.
# -------------------------------------------------------

# Resend (resend.com) — recommended
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ConvertKit / Kit form ID
# CONVERTKIT_FORM_ID=

# -------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# -------------------------------------------------------
